# Copy this file to .env and fill in your API keys
# .env is gitignored — never commit real keys.

# --- Google Gemini / ADK ---
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=false
# Default to Pro for best quality. Use flash for cheap iteration.
GEMINI_MODEL=gemini-2.5-pro
# If using Vertex AI instead of AI Studio:
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- ElevenLabs (optional, for premium narration voices) ---
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# --- Output config ---
DEFAULT_QUALITY=high_quality   # low_quality | medium_quality | high_quality | production_quality
OUTPUT_DIR=./output
